APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

GOOGLE_ANALYTICS_ID=

# Mautic Marketing Automation
MAUTIC_BASE_URL=http://localhost:8090
MAUTIC_API_USERNAME=admin
MAUTIC_API_PASSWORD=mautic_password
MAUTIC_TRACKING_ENABLED=true
MAUTIC_PIXEL_ID=
MAUTIC_WEBHOOK_SECRET=
MAUTIC_SYNC_ENABLED=true
MAUTIC_AUTO_CREATE_CONTACTS=true
MAUTIC_EMAIL_FROM=hello@example.com
MAUTIC_EMAIL_FROM_NAME=OnClick2Buy

# ERPNext Integration
ERPNEXT_BASE_URL=http://localhost:8000
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_SITE=erpnext.localhost
ERPNEXT_SYNC_ENABLED=true
ERPNEXT_AUTO_SYNC_PRODUCTS=true
ERPNEXT_AUTO_SYNC_ORDERS=true
ERPNEXT_AUTO_SYNC_INVENTORY=true
ERPNEXT_WAREHOUSE=Stores - OCC
ERPNEXT_COMPANY=OnClick2Buy
ERPNEXT_CUSTOMER_GROUP=All Customer Groups
ERPNEXT_TERRITORY=All Territories
ERPNEXT_ITEM_GROUP=All Item Groups
ERPNEXT_COST_CENTER=Cost Center - OCC
ERPNEXT_INCOME_ACCOUNT=Income - OCC
ERPNEXT_EXPENSE_ACCOUNT=Cost of Goods Sold - OCC
ERPNEXT_ACCOUNTS_RECEIVABLE=Accounts Receivable - OCC

# AI Agents Configuration
AI_AGENT_PROVIDER=rasa
RASA_URL=http://localhost:5005
RASA_ACTION_URL=http://localhost:5055
BOTPRESS_URL=http://localhost:3100
BOTPRESS_BOT_ID=ecommerce-bot
BOTFRAMEWORK_APP_ID=
BOTFRAMEWORK_APP_PASSWORD=
BOTFRAMEWORK_CHANNEL_ID=webchat
AI_HANDOFF_ENABLED=true
